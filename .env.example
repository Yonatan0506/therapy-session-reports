OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional model overrides
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4.1-mini
AUDIO_CHUNK_SECONDS=240
OPENAI_RETRY_ATTEMPTS=3
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
HOST=127.0.0.1
PORT=8787

# Optional: enables durable cloud-backed processing for long recordings.
# Create a private Cloud Storage bucket and a service account with Storage Object Admin on that bucket.
GCS_BUCKET=therapy-session-audio-temp
GOOGLE_CLOUD_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
DELETE_CLOUD_AUDIO_AFTER_SUCCESS=true

# Optional: prepares Cloud Run/Cloud Tasks worker mode.
# hybrid keeps current behavior and is safest while Render remains active.
# worker creates jobs only; an external worker must call /api/internal/process-job with the jobId.
PROCESSING_MODE=hybrid
PROCESSING_WORKER_TOKEN=replace-with-a-long-random-token
