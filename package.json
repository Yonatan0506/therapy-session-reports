{
  "name": "therapy-session-reports",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server:dev": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "tsx server/index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "docx": "^9.5.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "uuid": "^11.1.0",
    "vite": "^7.2.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9"
  }
}
